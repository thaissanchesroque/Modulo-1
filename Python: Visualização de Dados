      }
    },
    {
      "cell_type": "code",
      "source": [
        "import matplotlib.pyplot as plt\n",
        "import seaborn as sns\n",
        "\n",
        "plt.figure(figsize=(8,5))\n",
        "\n",
        "sns.histplot(\n",
        "    data=df,\n",
        "    x='Preço',\n",
        "    bins=20,\n",
        "    kde=False\n",
        ")\n",
        "\n",
        "plt.title('Distribuição de Preços (Histograma)')\n",
        "plt.xlabel('Preço')\n",
        "plt.ylabel('Frequência')\n",
